{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/pages/admin/index.js", "src/pages/index.js", "src/pages/update_request/index.js", "src/pages/project_review/[slug]/[id].js", "src/pages/project_review/index.js", "src/pages/signup/index.js", "src/pages/submit_coin/index.js", "src/pages/profile_details/index.js", "src/pages/login/index.js", "src/pages/listings/index.js", "src/pages/listicle/index.js", "src/pages/listicle/[slug]/[id].js", "src/pages/guestpost/index.js", "src/pages/guestpost/[slug]/[id].js", "src/pages/forgotPassword/index.js", "src/pages/contactus/index.js", "src/pages/blog/index.js", "src/pages/blog/[slug]/[id].js", "src/pages/advertise/index.js"],
  "exclude": ["node_modules"]
}
